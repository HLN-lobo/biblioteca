<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.4.5</version>
        <relativePath/>
    </parent>

    <groupId>com.biblioteca</groupId>
    <artifactId>qs</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <name>biblioteca-pessoal</name>
    <description>Gerenciador de Biblioteca Pessoal — MVC, MongoDB, Testcontainers, WireMock, SonarQube</description>

    <!-- ================================================================
         PROPRIEDADES GLOBAIS
    ================================================================ -->
    <properties>
        <java.version>21</java.version>

        <!-- Testcontainers BOM -->
        <testcontainers.version>1.20.4</testcontainers.version>

        <!--
            WireMock — usamos o starter específico para Spring Boot 3.x
            O 'wiremock-standalone' causa conflitos de classpath com
            Jackson/Jetty já presentes no Spring Boot 3.
        -->
        <wiremock.version>3.3.1</wiremock.version> 

        <!-- SonarQube / SonarCloud -->
        <!--
            ATENÇÃO: Substitua os valores abaixo pelos seus dados reais
            antes de rodar o pipeline pela primeira vez.

            sonar.organization  → nome da sua org no SonarCloud
            sonar.projectKey    → chave criada ao adicionar o projeto no SonarCloud
        -->
        <sonar.organization>seu-org-aqui</sonar.organization>
        <sonar.host.url>https://sonarcloud.io</sonar.host.url>
        <sonar.projectKey>biblioteca-pessoal</sonar.projectKey>

        <!-- Aponta o JaCoCo XML para o SonarQube ler a cobertura -->
        <sonar.coverage.jacoco.xmlReportPaths>
            ${project.build.directory}/site/jacoco/jacoco.xml
        </sonar.coverage.jacoco.xmlReportPaths>

        <!--
            Exclusões de cobertura: classes que não têm lógica testável
            (DTOs, configurações, exceções puras, entry-point da aplicação).
        -->
        <sonar.exclusions>
            **/config/**,
            **/dto/**,
            **/exception/**,
            **/*Application.java
        </sonar.exclusions>

        <!-- JaCoCo -->
        <jacoco.version>0.8.12</jacoco.version>

        <!-- Encoding -->
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
    </properties>

    <!-- ================================================================
         GERENCIAMENTO DE VERSÕES (BOM)
         Importamos o BOM do Testcontainers para não precisar declarar
         versão em cada módulo individualmente.
    ================================================================ -->
    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.testcontainers</groupId>
                <artifactId>testcontainers-bom</artifactId>
                <version>${testcontainers.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <!-- ================================================================
         DEPENDÊNCIAS DE PRODUÇÃO
    ================================================================ -->
    <dependencies>

        <!-- ── WEB ──────────────────────────────────────────────────── -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!-- Thymeleaf — camada View do MVC -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-thymeleaf</artifactId>
        </dependency>

        <!--
            Thymeleaf + Spring Security extras
            Habilita o dialeto sec:authorize, sec:authentication etc.
            nas templates Thymeleaf para controle de exibição por role.
        -->
        <dependency>
            <groupId>org.thymeleaf.extras</groupId>
            <artifactId>thymeleaf-extras-springsecurity6</artifactId>
        </dependency>

        <!-- ── SEGURANÇA ─────────────────────────────────────────────── -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>

        <!--
            Spring Session com MongoDB
            Persiste a sessão HTTP no MongoDB em vez de memória.
            Permite gerenciar sessões ativas, invalidar remotamente
            e funcionar em múltiplas instâncias (scale-out).
        -->
        <dependency>
            <groupId>org.springframework.session</groupId>
            <artifactId>spring-session-data-mongodb</artifactId>
        </dependency>

        <!-- ── BANCO DE DADOS ────────────────────────────────────────── -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-mongodb</artifactId>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>
        <!-- ── VALIDAÇÃO ─────────────────────────────────────────────── -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!-- ── ACTUATOR (health checks para CI/CD e monitoramento) ──── -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>

        <!-- ── DEVTOOLS (hot reload — apenas desenvolvimento) ────────── -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-devtools</artifactId>
            <scope>runtime</scope>
            <optional>true</optional>
        </dependency>

        <!-- ================================================================
             DEPENDÊNCIAS DE TESTE
             Todas com scope=test — não entram no artefato final.
        ================================================================ -->

        <!--
            Spring Boot Test
            Traz: JUnit 5, AssertJ, MockMvc, JSONPath, Hamcrest.

            IMPORTANTE: Mockito é EXCLUÍDO intencionalmente.
            O projeto não usa mocks — todos os testes usam
            infraestrutura real via TestContainers ou WireMock (VCR).
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
            <exclusions>
                <exclusion>
                    <groupId>org.mockito</groupId>
                    <artifactId>mockito-core</artifactId>
                </exclusion>
                <exclusion>
                    <groupId>org.mockito</groupId>
                    <artifactId>mockito-junit-jupiter</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <!-- Spring Security Test -->
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Testcontainers — core -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Testcontainers — módulo MongoDB -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>mongodb</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Testcontainers — integração JUnit 5 (@Testcontainers, @Container) -->
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>

        <!--
            Spring Boot Testcontainers
            Habilita @ServiceConnection: o Spring Boot detecta o container
            MongoDB automaticamente e configura a URI sem precisar de
            @DynamicPropertySource manual.
        -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-testcontainers</artifactId>
            <scope>test</scope>
        </dependency>

        <!--
            WireMock Spring Boot Starter
            Substitui o 'wiremock-standalone' para ambientes Spring Boot 3.x.

            Vantagens:
            - Sem conflitos de classpath (Jackson, Jetty, SLF4J)
            - Integração automática com o contexto Spring via @WireMockTest
            - Suporte a gravação e replay de chamadas HTTP reais (VCR)
        -->

        <!-- AssertJ — declarado explicitamente para deixar intenção clara -->
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <!-- ================================================================
         BUILD E PLUGINS
    ================================================================ -->
    <build>
        <plugins>

            <!-- Spring Boot Maven Plugin -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
            </plugin>

            <!-- Maven Compiler — Java 21 com suporte a Lombok -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>

            <!--
                Maven Surefire Plugin — testes UNITÁRIOS (*Test.java)
                Roda na fase 'test' (mvn test).

                Separação de responsabilidades:
                - Surefire  → testes unitários puros (sem Docker, sem I/O)
                - Failsafe  → testes de integração (TestContainers, WireMock)

                Os argLine com - -add-opens são necessários para Java 21
                (remoção de acesso a internals via reflections).
                O ${argLine} é injetado pelo JaCoCo (agente de cobertura).
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <includes>
                        <include>**/*Test.java</include>
                    </includes>
                    <excludes>
                        <!-- ITs ficam exclusivamente com o Failsafe -->
                        <exclude>**/*IT.java</exclude>
                    </excludes>
                    <argLine>
                        ${argLine}
                        --add-opens java.base/java.lang=ALL-UNNAMED
                        --add-opens java.base/java.util=ALL-UNNAMED
                    </argLine>
                </configuration>
            </plugin>

            <!--
                Maven Failsafe Plugin — testes de INTEGRAÇÃO (*IT.java)
                Roda na fase 'integration-test' (mvn verify).

                Por que Failsafe e não Surefire para ITs?
                - Failsafe não falha o build imediatamente; espera a fase
                  'post-integration-test' para parar os containers antes
                  de reportar falha → evita containers órfãos no CI.
                - Convenção clara: *Test.java = unitário, *IT.java = integração.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
                <configuration>
                    <includes>
                        <include>**/*IT.java</include>
                    </includes>
                    <argLine>
                        ${argLine}
                        --add-opens java.base/java.lang=ALL-UNNAMED
                        --add-opens java.base/java.util=ALL-UNNAMED
                    </argLine>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <!-- Executa os ITs -->
                            <goal>integration-test</goal>
                            <!-- Verifica resultados e falha o build se necessário -->
                            <goal>verify</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>

            <!--
                JaCoCo Maven Plugin — cobertura de código
                Integra com SonarQube via XML report.

                Fluxo:
                1. prepare-agent  → injeta o agente JaCoCo antes dos testes
                2. report         → gera o relatório XML após os testes
                3. check          → falha o build se cobertura < 80%
            -->
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>${jacoco.version}</version>
                <executions>

                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>

                    <execution>
                        <id>report</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>

                    <!--
                        Gate de qualidade: o build quebra se a cobertura
                        de linhas for menor que 80%.
                        Ajuste o valor em <minimum> conforme a maturidade
                        do projeto (pode começar em 0.60 e evoluir).
                    -->
                    <execution>
                        <id>check</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.80</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>

                </executions>
            </plugin>

            <!-- SonarQube Maven Plugin -->
            <plugin>
                <groupId>org.sonarsource.scanner.maven</groupId>
                <artifactId>sonar-maven-plugin</artifactId>
                <version>4.0.0.4121</version>
            </plugin>

        </plugins>
    </build>

</project>
